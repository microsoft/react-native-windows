<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- Enable /MP for parallel compilation of source files within each project.
       Using AdditionalOptions because MultiProcessorCompilation metadata was not
       being emitted as /MP in the CL command line (likely suppressed by file tracking). -->
  <ItemDefinitionGroup>
    <ClCompile>
      <MultiProcessorCompilation>true</MultiProcessorCompilation>
      <AdditionalOptions>%(AdditionalOptions) /MP</AdditionalOptions>
    </ClCompile>
  </ItemDefinitionGroup>
</Project>
