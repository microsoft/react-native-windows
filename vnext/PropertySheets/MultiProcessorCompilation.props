<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- CI build optimization: use CL.exe internal /MP parallelism instead of
       MSBuild's MultiToolTask (which spawns one CL.exe+Tracker.exe per file).

       MultiProcCL=false disables MultiToolTask so the normal CL task is used.
       /MP in AdditionalOptions lets CL.exe compile multiple files in one process
       with shared PCH state — much less overhead than 383 separate processes.

       File tracking is disabled since CI always does clean builds. -->
  <PropertyGroup>
    <MultiProcCL>false</MultiProcCL>
    <MinimalRebuildFromTracking>false</MinimalRebuildFromTracking>
    <TrackFileAccess>false</TrackFileAccess>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <MultiProcessorCompilation>false</MultiProcessorCompilation>
      <MinimalRebuild>false</MinimalRebuild>
      <AdditionalOptions>%(AdditionalOptions) /MP</AdditionalOptions>
    </ClCompile>
  </ItemDefinitionGroup>
</Project>
