    <ClInclude Include="$(ExternalDir)folly\folly\dynamic.h" />
    <ClInclude Include="$(ExternalDir)folly\folly\Exception.h" />
    <ClInclude Include="$(ExternalDir)folly\folly\ExceptionString.h" />
